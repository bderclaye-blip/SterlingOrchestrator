# STERLING ORCHESTRATOR — capture pipeline (Phase 1)
# Copy to worker/.env on the Mac Mini (and/or use for `supabase secrets set`).
# Do NOT commit real values.

# Supabase project: hkgjybzinahwminzfgwg
SUPABASE_URL=https://hkgjybzinahwminzfgwg.supabase.co

# Service-role key (Dashboard → Project Settings → API). Server-side ONLY — never ship to a browser.
SUPABASE_SERVICE_ROLE_KEY=

# Shared secret guarding the capture-thought webhook. Must match the value set via
# `supabase secrets set CAPTURE_SECRET=...` AND the x-capture-secret header in the ElevenLabs tool.
CAPTURE_SECRET=

# Absolute path to the Obsidian vault ROOT on the Mac Mini (used by the mirror worker).
# Phase 2: the worker routes each capture into a per-pillar folder UNDER this root
# (10-BarDeco, 20-NoosaWood, 30-AI-OS, 40-LCD, 50-Personal; unknown → 00-Inbox).
# Back-compat: if only the old VAULT_INBOX (.../00-Inbox) is set, its parent is used.
VAULT_ROOT=/Users/rasqualle_server/RASQUALLE-VAULT

# OPTIONAL — Claude enrichment (Phase 2 step 3). With this set, the worker runs a fast
# Haiku pass per capture to clean the title, add a one-line summary, and flag urgency.
# Leave blank to disable: captures still mirror, just without enrichment. Best-effort —
# an error or timeout falls back to the raw note.
ANTHROPIC_API_KEY=
# Optional override; defaults to claude-haiku-4-5.
ENRICH_MODEL=claude-haiku-4-5
