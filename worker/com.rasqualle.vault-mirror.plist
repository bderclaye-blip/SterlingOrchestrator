<?xml version="1.0" encoding="UTF-8"?>
<!--
  launchd template for the Mac Mini mirror worker.

  You normally don't edit this by hand — `deploy-on-mac-mini.sh` renders it
  (filling every __PLACEHOLDER__, including __NODE_BIN__ from `which node`),
  installs it to ~/Library/LaunchAgents/, and loads it.

  KeepAlive restarts it on crash; RunAtLoad starts it on login/reboot.
-->
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
    <key>Label</key>
    <string>com.rasqualle.vault-mirror</string>

    <key>ProgramArguments</key>
    <array>
        <string>__NODE_BIN__</string>
        <string>__REPO_PATH__/worker/vault-mirror.mjs</string>
    </array>

    <key>WorkingDirectory</key>
    <string>__REPO_PATH__/worker</string>

    <key>EnvironmentVariables</key>
    <dict>
        <key>SUPABASE_URL</key>
        <string>https://hkgjybzinahwminzfgwg.supabase.co</string>
        <key>SUPABASE_SERVICE_ROLE_KEY</key>
        <string>__SERVICE_ROLE_KEY__</string>
        <key>VAULT_INBOX</key>
        <string>__VAULT_INBOX_PATH__</string>
    </dict>

    <key>RunAtLoad</key>
    <true/>
    <key>KeepAlive</key>
    <true/>

    <key>StandardOutPath</key>
    <string>__REPO_PATH__/worker/vault-mirror.log</string>
    <key>StandardErrorPath</key>
    <string>__REPO_PATH__/worker/vault-mirror.error.log</string>
</dict>
</plist>
